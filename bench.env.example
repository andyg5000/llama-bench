# Remote server connection
BENCH_REMOTE_USER=root
BENCH_REMOTE_HOST=192.168.x.x
BENCH_SERVER_PORT=8099

# GPU identifier (used for output directory naming)
BENCH_GPU=gb10

# Model configuration
BENCH_MODEL=Qwen3.5-35B-A3B-Q8_0
BENCH_MODEL_PATH=/models/Qwen3.5-35B-A3B-Q8_0/Qwen3.5-35B-A3B-Q8_0.gguf
BENCH_CHAT_TEMPLATE=/models/Qwen3.5-35B-A3B-Q8_0/chat_template.jinja
BENCH_LLAMA_SERVER=/usr/local/bin/llama-server
